lib/core/config/payment_config.dart

# NOTE: firebase_options_*.dart / google-services.json are intentionally NOT
# ignored — they're Firebase client config (public identifiers, not secrets;
# protected by Firebase Security Rules, not secrecy). They're already
# committed — see CLAUDE.md if this decision needs revisiting.
#
# ios/Runner/GoogleService-Info.plist IS ignored: since the environment
# refactor, it's a build-time working copy generated by a Run Script build
# phase from the per-environment source files committed under
# ios/Runner/Firebase/{sit,uat,production}/GoogleService-Info.plist.
**/ios/Runner/GoogleService-Info.plist

